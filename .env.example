# Supabase (RLS debe estar activo: la anon key se expone al navegador)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu_anon_key_aqui

# App
NEXT_PUBLIC_APP_URL=https://tu-dominio.cl
NEXT_PUBLIC_COMMIT_SHA=dev

# Solo servidor (NO deben llevar prefijo NEXT_PUBLIC_)
SIMON_NOTIFICAR_SECRET=tu_secret_aqui
SENDGRID_API_KEY=tu_sendgrid_key_aqui
[email protected]

# Cron de recordatorio de caja chica (solo servidor)
# CRON_SECRET: secreto que Cron-job.org envia en Authorization: Bearer <...>
# SUPABASE_SERVICE_ROLE_KEY: llave service role, SOLO para el route del cron
CRON_SECRET=tu_cron_secret_aqui
SUPABASE_SERVICE_ROLE_KEY=tu_service_role_key_aqui
