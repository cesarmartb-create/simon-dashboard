NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Secreto compartido con el bot Simón para notificar al colaborador (header X-Secret)
SIMON_NOTIFICAR_SECRET=el-secreto-compartido-con-simon

# URL base pública del portal (para armar enlaces en correos, ej. escalamiento)
NEXT_PUBLIC_APP_URL=https://simon-dashboard-ochre.vercel.app

# SendGrid para correos de escalamiento
SENDGRID_API_KEY=tu-api-key-de-sendgrid
EMAIL_FROM=notificaciones@grupobaco.cl
